@{
    ViewData["Title"] = "Головна";
}

<div class="container mt-5">

    <!-- Заголовок -->

    <h1 class="text-center mb-4">
        Косметична компанія Beauty Cosmetics
    </h1>

    <!-- Опис -->

    <p class="lead text-center">
        Наша компанія пропонує професійну косметику
        для догляду за шкірою та волоссям.
    </p>

    <!-- Фото -->

    <div class="text-center">

        <img src="https://via.placeholder.com/800x300"
             class="img-fluid rounded shadow"
             alt="Cosmetics">

    </div>

    <!-- Таблиця -->

    <h2 class="mt-5">
        Наша продукція
    </h2>

    <table class="table table-bordered table-striped mt-3">

        <thead class="table-dark">

            <tr>
                <th>Продукт</th>
                <th>Характеристика</th>
                <th>Ціна</th>
            </tr>

        </thead>

        <tbody>

            <tr>
                <td>Крем для обличчя</td>
                <td>Зволоження шкіри</td>
                <td>450 грн</td>
            </tr>

            <tr>
                <td>Шампунь</td>
                <td>Відновлення волосся</td>
                <td>320 грн</td>
            </tr>

            <tr>
                <td>Парфуми</td>
                <td>Тривалий аромат</td>
                <td>1200 грн</td>
            </tr>

        </tbody>

    </table>

    <!-- Bootstrap Button -->

    <div class="mt-4">

        <button class="btn btn-primary btn-lg">
            Замовити продукцію
        </button>

    </div>

    <!-- Bootstrap Card -->

    <div class="card mt-5 shadow"
         style="width: 22rem;">

        <img src="https://via.placeholder.com/350x200"
             class="card-img-top"
             alt="Cream">

        <div class="card-body">

            <h5 class="card-title">
                Преміум крем
            </h5>

            <p class="card-text">

                Крем для щоденного догляду
                за шкірою обличчя.

            </p>

            <a href="#"
               class="btn btn-success">

                Купити

            </a>

        </div>

    </div>

    <!-- Bootstrap Input -->

    <div class="mt-5">

        <label class="form-label">
            Введіть email
        </label>

        <input type="email"
               class="form-control"
               placeholder="example@gmail.com">

    </div>

</div>
