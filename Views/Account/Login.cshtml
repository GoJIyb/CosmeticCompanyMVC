@model CosmeticCompanyMVC.Models.LoginViewModel

<h2>Вхід до системи</h2>

<form asp-action="Login" method="post">

    <div class="mb-3">
        <label>Логін</label>
        <input asp-for="Username"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Пароль</label>
        <input asp-for="Password"
               type="password"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-primary">
        Увійти
    </button>

</form>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mt-3">
        @ViewBag.Error
    </div>
}