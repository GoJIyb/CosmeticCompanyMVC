@page
@model CosmeticCompanyMVC.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
}

<h1 class="h3 mb-3 font-weight-normal">@ViewData["Title"]</h1>

<div class="row">
    <div class="col-md-4">
        <section>
            <form method="post" asp-route-returnUrl="@Model.ReturnUrl">
                <h4>Use a local account to log in.</h4>
                <hr />
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="Input.LoginOrEmail"></label>
                    <input asp-for="Input.LoginOrEmail" class="form-control" />
                    <span asp-validation-for="Input.LoginOrEmail" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Input.Password"></label>
                    <input asp-for="Input.Password" class="form-control" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-group form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label class="form-check-label" asp-for="Input.RememberMe"></label>
                </div>

                <button type="submit" class="btn btn-primary">Log in</button>
            </form>
        </section>
    </div>

    <div class="col-md-8">
        <section>
            <h3>External logins</h3>
            @if ((Model.ExternalLogins?.Count ?? 0) == 0)
            {
                <p>No external authentication providers configured.</p>
            }
            else
            {
                <form asp-route-returnUrl="@Model.ReturnUrl" method="post" asp-page-handler="ExternalLogin">
                    <div>
                        @foreach (var provider in Model.ExternalLogins)
                        {
                            <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name" title="Log in using @provider.DisplayName">
                                @provider.DisplayName
                            </button>
                        }
                    </div>
                </form>
            }
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}